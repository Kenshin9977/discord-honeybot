honeypot-ban-dm = Vous avez été banni de { $guild } car vous avez posté dans le canal restreint #{ $channel }. Si vous pensez que c'est une erreur, contactez { $contact }.
honeypot-kick-dm = Vous avez été expulsé de { $guild } car vous avez posté dans le canal restreint #{ $channel }. Si vous pensez que c'est une erreur, contactez { $contact }.
honeypot-timeout-dm = Vous avez été mis en sourdine sur { $guild } car vous avez posté dans le canal restreint #{ $channel }.

warn-issued = { $user } a reçu un avertissement. Raison : { $reason }. Total : { $count }.
warn-escalated = { $user } a atteint { $count } avertissements — action automatique : { $action }.

pool-joined = Pool { $name } rejoint en tant que { $role }.
pool-ban-applied = Ban fédéré appliqué : { $user } (depuis le pool { $pool }).
pool-ban-pending = Ban fédéré en attente de revue : { $user } (depuis le pool { $pool }).
