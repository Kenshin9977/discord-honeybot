# Copy to `.env` and fill in. The .env file is git-ignored.

# Required: your Discord bot token.
# Get one at https://discord.com/developers/applications → your app → Bot.
DISCORD_TOKEN=

# Optional: enable federation by pointing at a registry instance.
# Leave unset to run the bot in stand-alone mode.
# REGISTRY_URL=https://registry.example.com

# Optional: tracing verbosity. Examples: info, debug, honeybot=debug
RUST_LOG=info
